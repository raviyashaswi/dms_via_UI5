<mvc:View xmlns:core="sap.ui.core"
    xmlns:unified="sap.ui.unified"
    xmlns:form="sap.ui.layout.form" controllerName="com.cy.dms.dmsthroughui5.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
        <!-- <Image id="_IDGenImage" src='data:image/png;base64,'></Image>
        <Image id="_IDGenImage2" densityAware="false" src="{content>/image}"></Image> -->
        <form:SimpleForm id="_IDGenSimpleForm">
            <Label id="_IDGenLabel" text="repository"></Label>
            <Select selectedKey="{content>/selected/repo}" id="_IDGenSelect" items="{content>/repos}">
                <items>
                    <core:Item id="_IDGenItem"
                        xmlns:core="sap.ui.core" key="{content>repositoryId}" text="{content>repositoryName}" />
                </items>
            </Select>
            <Label id="_IDGenLabel1" text="objects"></Label>

            <Button id="_IDGenButton" icon="sap-icon://down" type="Accept" press=".objects"></Button>

        </form:SimpleForm>
        <Table id="_IDGenTable" class="sapUiMediumMargin" items = "{content>/objects}" itemPress="folder">
            <columns>
                <Column id="_IDGenColumn">
                    <Text id="_IDGenText1" text="Name"></Text>
                </Column>
                <Column id="_IDGenColumn1">
                    <Text id="_IDGenText2" text="Type"></Text>
                </Column>
                <Column id="_IDGenColumn2">
                    <Text id="_IDGenText3" text="Actions"></Text>
                </Column>
            </columns>
            <items>
                <ColumnListItem id="_IDGenColumnListItem" type="Navigation">
                    <cells>
                        <Text id="_IDGenText" text="{content>object/properties/cmis:name/value} + {content>object/properties/cmis:contentStreamFileName/value}"></Text>
                        <Text id="_IDGenText4" text="{content>object/properties/cmis:baseTypeId/value}"></Text>
                        <Button id="_IDGenButton3" icon="sap-icon://delete" press="delete" type="Negative"></Button>

                    </cells>
                </ColumnListItem>
            </items>
        </Table>
        <Table id="_IDGenTable1" class="sapUiMediumMargin" items = "{content>/folderItems}" itemPress="folder">
            <columns>
                <Column id="_IDGenColumn3">
                    <Text id="_IDGenText5" text="Name"></Text>
                </Column>
                <Column id="_IDGenColumn4">
                    <Text id="_IDGenText6" text="Type"></Text>
                </Column>
                <Column id="_IDGenColumn5">
                    <Text id="_IDGenText7" text="Actions"></Text>
                </Column>
            </columns>
            <items>
                <ColumnListItem id="_IDGenColumnListItem1" type="Navigation">
                    <cells>
                        <Text id="_IDGenText8" text="{content>object/properties/cmis:name/value} + {content>object/properties/cmis:contentStreamFileName/value}"></Text>
                        <Text id="_IDGenText9" text="{content>object/properties/cmis:baseTypeId/value}"></Text>
                        <Button id="_IDGenButton2" icon="sap-icon://delete" press="delete" type="Reject"></Button>
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
        <unified:FileUploader id="_IDGenFileUploader" name="myFileUpload" tooltip="Upload your file to DMS" uploadComplete="handleUploadComplete"></unified:FileUploader>
        <Button id="_IDGenButton1" text="Upload File" press="handleUploadPress"/>
        <!-- <PDFViewer id="_IDGenPDFViewer" source="{content>/image}" isTrustedSource="true" title="{content>/image}" height="100%" width="100%">
				<layoutData>
					<FlexItemData id="_IDGenFlexItemData2" growFactor="1" />
				</layoutData>
			</PDFViewer> -->
        <!-- <core:HTML id="pdfHtmlControl" content='&lt;object data="{content>/image}" type="application/pdf" width="100%" height="600px"&gt;&lt;/object&gt;' /> -->
        <Link id="_IDGenLink1" text="doc" href="{content>/image}" target="__blank"></Link>
    </Page>
</mvc:View>